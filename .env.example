# CeliacMap — agent configuration (copy to .env and fill in).
# Secrets are server-side only: keep them in .env locally and in GitHub Actions
# Secrets in CI. NEVER expose the service_role or any API key in the frontend.

# --- Supabase (service_role: bypasses RLS, agents only) ---------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Paid APIs --------------------------------------------------------
GOOGLE_MAPS_API_KEY=        # Google Places (Search / Updater / Social agents)
ANTHROPIC_API_KEY=          # Claude API (Validator; Updater + Social haiku)

# --- Tavily Search (Social agent) -------------------------------------
# Tavily web search, used to discover public Instagram / Facebook pages.
# Free tier: 1000 searches/month. Sign up at https://tavily.com
TAVILY_API_KEY=

# --- Models (optional; sensible defaults shown) -----------------------
VALIDATOR_MODEL=claude-sonnet-4-6
HAIKU_MODEL=claude-haiku-4-5

# --- Run caps / budget (optional; defaults shown) ---------------------
MAX_SEARCH_RESULTS_PER_QUERY=20
MAX_VALIDATIONS_PER_RUN=50
MAX_UPDATES_PER_RUN=50
# Social agent caps (kept well under the Tavily 1000/month free tier).
MAX_SOCIAL_QUERIES_PER_RUN=16
MAX_REVIEW_ENRICHMENTS_PER_RUN=30
# Combined cap on paid API calls for one full pipeline run (run_agents.py).
AGENT_DAILY_BUDGET=200
