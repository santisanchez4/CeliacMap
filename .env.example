# CeliacMap — agent environment (server-side only)
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# These keys are for the Python agents / CI only — the frontend uses the
# public anon key in js/config.js, never anything below.

# --- Supabase ---------------------------------------------------------
# service_role bypasses Row Level Security — keep it secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Places ----------------------------------------------------
# Requires a Google Cloud project with the Places API enabled and billing on.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Anthropic (Validator) -------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Models -----------------------------------------------------------
VALIDATOR_MODEL=claude-sonnet-4-6
HAIKU_MODEL=claude-haiku-4-5

# --- Per-run cost guardrails -----------------------------------------
MAX_SEARCH_RESULTS_PER_QUERY=20
MAX_VALIDATIONS_PER_RUN=50
